# =====================================================================
# AI Educator Backend — environment variables
# Copy to .env and fill in values. NEVER commit .env.
# Only DATABASE_URL (in prod), GROQ_API_KEY, and Firebase credentials
# are required; everything else has sensible defaults.
# =====================================================================

# ── Environment ──────────────────────────────────────────────────────
# prod/production/staging require DATABASE_URL (no SQLite fallback).
APP_ENV=development
# ENVIRONMENT=            # alias for APP_ENV
# ENV=                    # alias for APP_ENV

# ── Database ─────────────────────────────────────────────────────────
# postgresql://user:password@host:5432/dbname  (driver auto-selected)
DATABASE_URL=
# ALLOW_SQLITE_FALLBACK=true     # explicit local SQLite opt-in
# REQUIRE_DATABASE_URL=false     # force-fail boot without DATABASE_URL

# ── Firebase Auth (required for all authenticated routes) ────────────
FIREBASE_PROJECT_ID=
# Either the full service-account JSON inline, or a path to the file:
FIREBASE_SERVICE_ACCOUNT_JSON=
# GOOGLE_APPLICATION_CREDENTIALS=   # alternative: path to credentials file

# ── Admin access (comma-separated allowlists) ────────────────────────
BACKEND_ADMIN_EMAILS=
# BACKEND_ADMIN_UIDS=
# BACKEND_ADMIN_PHONES=
# BACKEND_FOUNDER_ADMIN_EMAILS=   # defaults to BACKEND_ADMIN_EMAILS

# ── LLM providers ────────────────────────────────────────────────────
GROQ_API_KEY=
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# COACH_LLM_PROVIDER=groq
# COACH_PROVIDER_ORDER=groq,openrouter,openai
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_SITE_URL=https://agentifyai.in
# OPENROUTER_APP_NAME=AgentifyAI
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Model selection (Groq model ids per role) ────────────────────────
# GROQ_FAST_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_TUTOR_MODEL=openai/gpt-oss-120b
# GROQ_REVIEW_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_FALLBACK_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_EXAM_MODEL=
# GROQ_REVISION_MODEL=
# GROQ_PLANNER_MODEL=
# GROQ_CASUAL_MODEL=
# GROQ_FEEDBACK_MODEL=
# EMBEDDING_MODEL=                # not yet wired; reserved

# ── Coach LLM routing, budgets, timeouts ─────────────────────────────
# COACH_LLM_TIMEOUT_SECONDS=22
# COACH_LLM_MAX_ATTEMPTS=2
# COACH_ROUTE_PREFERENCE=balanced   # or lowest_cost
# COACH_BUDGET_ROUTING=true
# COACH_TURN_BUDGET_USD=0           # 0 disables per-turn budget
# COACH_DAILY_BUDGET_USD=0          # 0 disables daily budget
# COACH_ROUTE_OUTPUT_TOKEN_ESTIMATE=700
# COACH_MODEL_PRICES_PER_1M=        # model=input_usd:output_usd;other=...
# COACH_DEFAULT_INPUT_USD_PER_1M=0.20
# COACH_DEFAULT_OUTPUT_USD_PER_1M=0.60
# COACH_VISION_IMAGE_TOKEN_ESTIMATE=800

# ── Coach retrieval, memory, attachments ─────────────────────────────
# COACH_STRICT_GROUNDING=false
# COACH_NOT_FOUND_MESSAGE=
# COACH_MAX_RETRIEVAL_CHARS=5000
# COACH_MAX_RETRIEVAL_PARAGRAPHS=8
# COACH_MEMORY_LIMIT=6
# COACH_INTERACTION_LIMIT=8
# COACH_MAX_ATTACHMENTS=5
# COACH_MAX_IMAGE_ATTACHMENTS=5
# COACH_MAX_IMAGE_BYTES=4194304
# COACH_MAX_DOCUMENT_BYTES=6291456
# COACH_MAX_ATTACHMENT_CHARS=12000
# COACH_MAX_PDF_PAGES=8

# ── Rate limits & quotas ─────────────────────────────────────────────
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PER_MINUTE=120
# AI_RATE_LIMIT_PER_MINUTE=24
# ADMIN_RATE_LIMIT_PER_MINUTE=180
# AI_DAILY_QUOTA_PER_USER=180
# EXAM_DAILY_QUOTA_PER_USER=80
# ARTIFACT_DAILY_QUOTA_PER_USER=40

# ── CORS ─────────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=http://localhost:3000,https://agentifyai.in

# ── Behavior flags ───────────────────────────────────────────────────
# ALLOW_CLIENT_PROGRESS_OVERWRITE=false

# ── Observability (OpenTelemetry; disabled when unset) ───────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=     # e.g. Langfuse/Tempo/Jaeger OTLP HTTP endpoint
# OTEL_EXPORTER_OTLP_HEADERS=      # e.g. Authorization=Basic%20...
# OTEL_SERVICE_NAME=ai-educator-backend
# OTEL_TRACES_EXPORTER=            # set to "console" for local span debugging

# ── Version labels (admin model registry display) ────────────────────
# PROMPT_VERSION=agentic-control-plane-v1
# AGENT_WORKFLOW_VERSION=agentic-control-plane-v1
# RENDER_GIT_COMMIT=               # set automatically by Render
